# ===========================================================================
# Modelo de variáveis de ambiente. Copie para `.env` e preencha.
# NUNCA commite o `.env` real nem os JSONs de credencial.
# ===========================================================================

# --- Servidor ---
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# --- Google Sheets (OAuth do usuário — caminho escolhido, ver CLAUDE.md §Decisões) ---
# O usuário faz login com Google e autoriza o app a ler/escrever suas planilhas.
# Crie as credenciais OAuth no Google Cloud Console (tipo "Web application").
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/auth/google/callback

# --- OCR (Cloudflare OCR Worker) ---
# PDF → texto (faz a camada de texto E o OCR de escaneados server-side).
# OCR_WORKER_TOKEN é SEGREDO: preencha só no .env real, nunca commite.
OCR_WORKER_URL=
OCR_WORKER_TOKEN=
# Timeout da chamada ao worker, em ms (OCR pode demorar).
OCR_WORKER_TIMEOUT_MS=60000

# --- IA / AI Proxy (GoGroup, gateway OpenAI-compatível — Conferência v2, fatia C3) ---
# Extrai os campos da NF do texto do OCR (e mapeia colunas, na C2). Mesmo gateway do godocs.
# Com LLM_BASE_URL definida → modo proxy (autentica com API_PROXY_TOKEN).
# Sem LLM_BASE_URL → chamada direta (autentica com LLM_API_KEY).
# API_PROXY_TOKEN / LLM_API_KEY são SEGREDOS: só no .env real, nunca commite (§6).
LLM_BASE_URL=
API_PROXY_TOKEN=
LLM_API_KEY=
LLM_MODEL=gpt-4.1-mini
LLM_PROVIDER=openai

# --- Banco de dados (fila de jobs / histórico) ---
DATABASE_URL=postgresql://user:pass@localhost:5432/nf_analyzer

# --- Fila / workers (opcional, ex.: Redis para BullMQ) ---
REDIS_URL=redis://localhost:6379

# --- Limites do pipeline ---
MAX_CONCURRENT_DOWNLOADS=4
MAX_PDF_SIZE_MB=20
HTTP_TIMEOUT_MS=30000

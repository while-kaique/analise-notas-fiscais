# ===========================================================================
# Modelo de variáveis de ambiente. Copie para `.env` e preencha.
# NUNCA commite o `.env` real nem os JSONs de credencial.
# ===========================================================================

# --- Servidor ---
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# --- Google Sheets (OAuth do usuário — caminho escolhido, ver CLAUDE.md §Decisões) ---
# O usuário faz login com Google e autoriza o app a ler/escrever suas planilhas.
# Crie as credenciais OAuth no Google Cloud Console (tipo "Web application").
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/auth/google/callback

# --- OCR ---
# Estratégia de OCR: "tesseract" (local) | "cloud-vision" | "textract"
OCR_PROVIDER=tesseract
# Se usar Google Cloud Vision, reaproveita GOOGLE_APPLICATION_CREDENTIALS.
# Idioma(s) do Tesseract (ex.: por, eng, por+eng)
OCR_LANGS=por

# --- Banco de dados (fila de jobs / histórico) ---
DATABASE_URL=postgresql://user:pass@localhost:5432/nf_analyzer

# --- Fila / workers (opcional, ex.: Redis para BullMQ) ---
REDIS_URL=redis://localhost:6379

# --- Limites do pipeline ---
MAX_CONCURRENT_DOWNLOADS=4
MAX_PDF_SIZE_MB=20
HTTP_TIMEOUT_MS=30000

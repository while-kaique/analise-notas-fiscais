# ===========================================================================
# Modelo de variáveis de ambiente — v2 · Conferência de NF por Cupom.
# No deploy (GoDeploy/Workers) estes valores são SECRETS (setAppSecret), não .env.
# Copie para `.env` para dev local. NUNCA commite o `.env` real nem tokens.
# ===========================================================================

# --- Identidade de serviço: rpa_ia@gocase.com (decisão 11) ---
# O cron lê o Drive e escreve nas planilhas como a rpa_ia, via REFRESH TOKEN
# (consentimento offline 1x, tela de consentimento OAuth PUBLICADA / "Em produção").
# NÃO é OAuth por usuário nem Service Account. CLIENT_ID/SECRET são do app OAuth da rpa_ia.
# GOOGLE_OAUTH_REFRESH_TOKEN é SEGREDO: só no .env real / setAppSecret, nunca commite (§6).
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
# Usado só para GERAR a URL de consentimento offline (urlConsentimentoServico).
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/auth/google/callback

# --- OCR (Cloudflare OCR Worker) ---
# PDF → texto (faz a camada de texto E o OCR de escaneados server-side).
# OCR_WORKER_TOKEN é SEGREDO: preencha só no .env real, nunca commite.
OCR_WORKER_URL=
OCR_WORKER_TOKEN=
# Timeout da chamada ao worker, em ms (OCR pode demorar).
OCR_WORKER_TIMEOUT_MS=60000

# --- IA / AI Proxy (GoGroup, gateway OpenAI-compatível) ---
# Extrai os campos da NF do texto do OCR (C3) e mapeia colunas (C2). Mesmo gateway do godocs.
# Com LLM_BASE_URL definida → modo proxy (autentica com API_PROXY_TOKEN).
# Sem LLM_BASE_URL → chamada direta (autentica com LLM_API_KEY).
# API_PROXY_TOKEN / LLM_API_KEY são SEGREDOS: só no .env real, nunca commite (§6).
LLM_BASE_URL=
API_PROXY_TOKEN=
LLM_API_KEY=
# O AI Proxy GoGroup serve modelos gpt-5.x (gpt-5.5/gpt-5.4/gpt-5.4-mini). Confira com
# GET /v1/models. Modelo inexistente no proxy retorna HTTP 502 (não 400/404).
LLM_MODEL=gpt-5.4-mini
LLM_PROVIDER=openai

# --- Processamento (cron + env.DB) ---
# Quantos cupons o cron processa por frente a cada tick (lote). Default 25.
CONF_BATCH_SIZE=25
# Chave usada pela plataforma para autenticar a chamada do cron (POST /tasks/processar).
GODEPLOY_CRON_KEY=
# Segredo p/ assinar o cookie de sessão (HMAC) — opcional, controle interno.
SESSION_SECRET=
